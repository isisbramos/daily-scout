{
  "_comment": "Daily Scout v5 — Sources Configuration. Liga/desliga fontes sem mudar código.",

  "sources": {
    "reddit": {
      "enabled": true,
      "weight": 1.0,
      "subreddits": [
        "artificial", "MachineLearning", "ChatGPT", "LocalLLaMA",
        "technology", "programming", "opensource", "singularity",
        "techNews", "ArtificialIntelligence", "compsci",
        "startups", "SideProject"
      ],
      "limit_per_sub": 10,
      "rate_limit_delay": 0.5
    },
    "hackernews": {
      "enabled": true,
      "weight": 1.2,
      "limit": 30,
      "timeout": 15
    },
    "techcrunch": {
      "enabled": true,
      "weight": 1.1,
      "limit": 20,
      "feeds": {
        "main": "https://techcrunch.com/feed/"
      }
    },
    "lobsters": {
      "enabled": true,
      "weight": 0.9,
      "limit": 25,
      "rss_url": "https://lobste.rs/rss"
    },

    "_comment_primary": "T1 Primary Sources — pesquisa acadêmica original. Peso 1.3 (maior do sistema). Papers são candidatos naturais ao RADAR. Não são blogs corporativos — STEP 1.5 não se aplica.",
    "arxiv_ai": {
      "enabled": true,
      "weight": 1.3,
      "tier": "T1",
      "limit": 15,
      "feeds": {
        "cs_ai": "https://rss.arxiv.org/rss/cs.AI",
        "cs_lg": "https://rss.arxiv.org/rss/cs.LG",
        "cs_cl": "https://rss.arxiv.org/rss/cs.CL"
      }
    },
    "huggingface_papers": {
      "enabled": true,
      "_comment": "Papers em trending na comunidade HuggingFace — já pré-filtrados por tração da comunidade de ML. Feed confirmado e habilitado em 2026-04-19.",
      "weight": 1.3,
      "tier": "T1",
      "limit": 20,
      "rss_url": "https://huggingface.co/papers.rss"
    },

    "_comment_ai_labs": "AI Lab Blogs — weight 0.8 (abaixo de community sources; blogs oficiais são marketing-heavy)",
    "anthropic_blog": {
      "enabled": true,
      "weight": 0.8,
      "limit": 15,
      "rss_url": "https://www.anthropic.com/feed"
    },
    "openai_blog": {
      "enabled": true,
      "weight": 0.8,
      "limit": 15,
      "rss_url": "https://openai.com/blog/rss.xml"
    },
    "deepmind_blog": {
      "enabled": true,
      "weight": 0.7,
      "limit": 15,
      "rss_url": "https://deepmind.google/blog/rss.xml"
    },

    "_comment_geographic": "Geographic Diversity — fontes não-ocidentais para quebrar echo chamber. Weights reduzidos v5.2 para evitar over-representation",
    "scmp_tech": {
      "enabled": true,
      "weight": 0.9,
      "limit": 15,
      "region": "asia",
      "rss_url": "https://www.scmp.com/rss/36/feed"
    },
    "rest_of_world": {
      "enabled": true,
      "weight": 0.9,
      "limit": 15,
      "region": "global_south",
      "rss_url": "https://restofworld.org/feed/"
    },
    "technode": {
      "enabled": true,
      "weight": 0.8,
      "limit": 15,
      "region": "asia",
      "rss_url": "https://technode.com/feed/"
    }
